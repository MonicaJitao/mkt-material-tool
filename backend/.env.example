# 后端环境变量示例 — 复制为 .env 并填入真实值

# ── 应用 ──────────────────────────────────────────
APP_NAME=mkt-material-tool
DEBUG=false

# ── 数据库 ────────────────────────────────────────
# SQLite 文件路径（相对于 backend/ 目录）
DATABASE_URL=sqlite:///./workspace/mkt_material.db

# ── 工作区 ────────────────────────────────────────
WORKSPACE_DIR=workspace

# ── Tuzi Banana 生图（Agent B 使用）──────────────
TUZI_API_KEY=sk-your-tuzi-key-here
TUZI_API_BASE=https://api.tu-zi.com
TUZI_IMAGE_MODEL=gemini-3-pro-image-preview-2k-async

# ── Anthropic / Claude（Agent C 使用）────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=12000

# ── DeepSeek（Anthropic 兼容接口）───────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
